{
  "name": "betterkv-www",
  "private": true,
  "workspaces": [
    "./*"
  ],
  "scripts": {
    "dev:landing": "bun run --filter betterkv-landing dev",
    "dev:docs": "bun run --filter betterkv-docs dev",
    "dev:server": "bun run --filter betterkv-server dev",
    "check": "biome check landing docs server",
    "check:fix": "biome check --write landing docs server",
    "format": "bun run format:landing && bun run format:docs && bun run format:server",
    "format:landing": "bun run --filter betterkv-landing format",
    "format:docs": "bun run --filter betterkv-docs format",
    "format:server": "bun run --filter betterkv-server format",
    "lint": "biome lint landing docs server",
    "deploy": "bun run deploy:landing && bun run deploy:docs && bun run deploy:server",
    "deploy:landing": "bun run --filter betterkv-landing deploy",
    "deploy:docs": "bun run --filter betterkv-docs deploy",
    "deploy:server": "bun run --filter betterkv-server deploy"
  },
  "devDependencies": {
    "@biomejs/biome": "^1.9.4"
  }
}
