# LINDEX, LLEN command tests - List access operations
@name LINDEX-LLEN
@group lists
@since 1.0.0

=== TEST: LINDEX basic
SETUP:
RPUSH mylist "a" "b" "c"
RUN:
LINDEX mylist 0
EXPECT:
"a"
CLEANUP:
DEL mylist

=== TEST: LINDEX middle
SETUP:
RPUSH mylist "a" "b" "c"
RUN:
LINDEX mylist 1
EXPECT:
"b"
CLEANUP:
DEL mylist

=== TEST: LINDEX last
SETUP:
RPUSH mylist "a" "b" "c"
RUN:
LINDEX mylist -1
EXPECT:
"c"
CLEANUP:
DEL mylist

=== TEST: LINDEX out of range
SETUP:
RPUSH mylist "a" "b" "c"
RUN:
LINDEX mylist 10
EXPECT:
(nil)
CLEANUP:
DEL mylist

=== TEST: LINDEX negative out of range
SETUP:
RPUSH mylist "a" "b" "c"
RUN:
LINDEX mylist -10
EXPECT:
(nil)
CLEANUP:
DEL mylist

=== TEST: LINDEX non-existing list
SETUP:
DEL mylist
RUN:
LINDEX mylist 0
EXPECT:
(nil)

=== TEST: LINDEX wrong type
SETUP:
SET mystring "value"
RUN:
LINDEX mystring 0
EXPECT:
(error) WRONGTYPE Operation against a key holding the wrong kind of value
CLEANUP:
DEL mystring

=== TEST: LLEN basic
SETUP:
RPUSH mylist "a" "b" "c"
RUN:
LLEN mylist
EXPECT:
(integer) 3
CLEANUP:
DEL mylist

=== TEST: LLEN single element
SETUP:
RPUSH mylist "a"
RUN:
LLEN mylist
EXPECT:
(integer) 1
CLEANUP:
DEL mylist

=== TEST: LLEN empty list
SETUP:
DEL mylist
RUN:
LLEN mylist
EXPECT:
(integer) 0

=== TEST: LLEN non-existing list
SETUP:
DEL nonexistent
RUN:
LLEN nonexistent
EXPECT:
(integer) 0

=== TEST: LLEN wrong type
SETUP:
SET mystring "value"
RUN:
LLEN mystring
EXPECT:
(error) WRONGTYPE Operation against a key holding the wrong kind of value
CLEANUP:
DEL mystring
