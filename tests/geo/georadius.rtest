# GEORADIUS, GEORADIUSBYMEMBER command tests - Geo radius queries
@name GEORADIUS
@group geo
@since 3.2.0

=== TEST: GEORADIUS basic
SETUP:
GEOADD Sicily 13.361389 38.115556 "Palermo" 15.087269 37.502669 "Catania"
RUN:
GEORADIUS Sicily 15 37 200 km
EXPECT:
(any)
CLEANUP:
DEL Sicily

=== TEST: GEORADIUS with WITHCOORD
SETUP:
GEOADD Sicily 13.361389 38.115556 "Palermo" 15.087269 37.502669 "Catania"
RUN:
GEORADIUS Sicily 15 37 200 km WITHCOORD
EXPECT:
(any)
CLEANUP:
DEL Sicily

=== TEST: GEORADIUS with WITHDIST
SETUP:
GEOADD Sicily 13.361389 38.115556 "Palermo" 15.087269 37.502669 "Catania"
RUN:
GEORADIUS Sicily 15 37 200 km WITHDIST
EXPECT:
(any)
CLEANUP:
DEL Sicily

=== TEST: GEORADIUS with COUNT
SETUP:
GEOADD Sicily 13.361389 38.115556 "Palermo" 15.087269 37.502669 "Catania"
RUN:
GEORADIUS Sicily 15 37 200 km COUNT 1
EXPECT:
(any)
CLEANUP:
DEL Sicily

=== TEST: GEORADIUSBYMEMBER basic
SETUP:
GEOADD Sicily 13.361389 38.115556 "Palermo" 15.087269 37.502669 "Catania"
RUN:
GEORADIUSBYMEMBER Sicily "Palermo" 200 km
EXPECT:
(any)
CLEANUP:
DEL Sicily

=== TEST: GEORADIUSBYMEMBER with WITHDIST
SETUP:
GEOADD Sicily 13.361389 38.115556 "Palermo" 15.087269 37.502669 "Catania"
RUN:
GEORADIUSBYMEMBER Sicily "Palermo" 200 km WITHDIST
EXPECT:
(any)
CLEANUP:
DEL Sicily

=== TEST: GEOSEARCH (6.2+)
SETUP:
GEOADD Sicily 13.361389 38.115556 "Palermo" 15.087269 37.502669 "Catania"
RUN:
GEOSEARCH Sicily FROMMEMBER "Palermo" BYRADIUS 200 km
EXPECT:
(any)
CLEANUP:
DEL Sicily

=== TEST: GEOSEARCHSTORE (6.2+)
SETUP:
GEOADD Sicily 13.361389 38.115556 "Palermo" 15.087269 37.502669 "Catania"
DEL result
RUN:
GEOSEARCHSTORE result Sicily FROMMEMBER "Palermo" BYRADIUS 200 km
EXPECT:
(integer) (any)
CLEANUP:
DEL Sicily result

=== TEST: GEORADIUS non-existing key
SETUP:
DEL Sicily
RUN:
GEORADIUS Sicily 15 37 200 km
EXPECT:
(empty array)

=== TEST: GEORADIUS wrong unit
SETUP:
GEOADD Sicily 13.361389 38.115556 "Palermo"
RUN:
GEORADIUS Sicily 15 37 200 invalid
EXPECT:
(error) ERR unsupported unit provided
CLEANUP:
DEL Sicily
