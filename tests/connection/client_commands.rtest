# CLIENT command tests - Client management
@name CLIENT
@group connection
@since 2.4.0

=== TEST: CLIENT SETNAME
RUN:
CLIENT SETNAME "myconnection"
EXPECT:
OK

=== TEST: CLIENT GETNAME after SETNAME
SETUP:
CLIENT SETNAME "myconnection"
RUN:
CLIENT GETNAME
EXPECT:
"myconnection"

=== TEST: CLIENT GETNAME default
RUN:
CLIENT GETNAME
EXPECT:
(nil)

=== TEST: CLIENT ID
RUN:
CLIENT ID
EXPECT:
(integer) (any)

=== TEST: CLIENT LIST
RUN:
CLIENT LIST
EXPECT:
(any)

=== TEST: CLIENT INFO (6.2+)
RUN:
CLIENT INFO
EXPECT:
(any)

=== TEST: CLIENT REPLY ON
RUN:
CLIENT REPLY ON
EXPECT:
OK

=== TEST: CLIENT REPLY OFF
RUN:
CLIENT REPLY OFF
EXPECT:
OK

=== TEST: CLIENT REPLY SKIP
RUN:
CLIENT REPLY SKIP
EXPECT:
(any)

=== TEST: CLIENT PAUSE
RUN:
CLIENT PAUSE 100
EXPECT:
OK

=== TEST: CLIENT UNPAUSE (6.2+)
RUN:
CLIENT UNPAUSE
EXPECT:
OK

=== TEST: CLIENT TRACKING
RUN:
CLIENT TRACKING ON
EXPECT:
OK

=== TEST: CLIENT TRACKINGINFO (6.2+)
RUN:
CLIENT TRACKINGINFO
EXPECT:
(any)

=== TEST: CLIENT SETNAME empty
RUN:
CLIENT SETNAME ""
EXPECT:
OK
