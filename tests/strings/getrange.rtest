# GETRANGE command tests - Get substring of string value
@name GETRANGE
@group strings
@since 2.4.0

=== TEST: GETRANGE basic
SETUP:
SET mykey "This is a string"
RUN:
GETRANGE mykey 0 3
EXPECT:
"This"
CLEANUP:
DEL mykey

=== TEST: GETRANGE full string
SETUP:
SET mykey "Hello"
RUN:
GETRANGE mykey 0 -1
EXPECT:
"Hello"
CLEANUP:
DEL mykey

=== TEST: GETRANGE negative indices
SETUP:
SET mykey "Hello World"
RUN:
GETRANGE mykey -5 -1
EXPECT:
"World"
CLEANUP:
DEL mykey

=== TEST: GETRANGE out of range
SETUP:
SET mykey "Hello"
RUN:
GETRANGE mykey 0 100
EXPECT:
"Hello"
CLEANUP:
DEL mykey

=== TEST: GETRANGE empty range
SETUP:
SET mykey "Hello"
RUN:
GETRANGE mykey 5 4
EXPECT:
""
CLEANUP:
DEL mykey

=== TEST: GETRANGE non-existing key
SETUP:
DEL nonexistent
RUN:
GETRANGE nonexistent 0 10
EXPECT:
""

=== TEST: GETRANGE wrong number of arguments
RUN:
GETRANGE key
EXPECT:
(error) ERR wrong number of arguments for 'getrange' command
