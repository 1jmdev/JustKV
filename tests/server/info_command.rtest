=== TEST: DBSIZE basic
SETUP:
SET key1 "value1"
SET key2 "value2"
RUN:
DBSIZE
EXPECT:
(integer) (any)
CLEANUP:
DEL key1 key2

=== TEST: DBSIZE empty database
SETUP:
FLUSHDB
RUN:
DBSIZE
EXPECT:
(integer) 0

=== TEST: FLUSHDB basic
SETUP:
SET key "value"
RUN:
FLUSHDB
EXPECT:
OK

=== TEST: FLUSHDB clears keys
SETUP:
SET key "value"
FLUSHDB
RUN:
DBSIZE
EXPECT:
(integer) 0

=== TEST: FLUSHALL clears all databases
RUN:
FLUSHALL
EXPECT:
OK

