@name INFO
@group server
@since 6.2.0

=== TEST: Get all server info
RUN:
INFO
EXPECT:
(match) .*

=== TEST: Get server section
RUN:
INFO server
EXPECT:
(match) .*

=== TEST: Get stats section
RUN:
INFO stats
EXPECT:
(match) .*

=== TEST: Get clients section
RUN:
INFO clients
EXPECT:
(match) .*

=== TEST: Get memory section
RUN:
INFO memory
EXPECT:
(match) .*

=== TEST: Get multiple sections
RUN:
INFO server clients
EXPECT:
(match) .*

---

